{
  "manifest_version": 3,
  "name": "PCE - AI Interaction Capture",
  "version": "0.3.0",
  "description": "Captures AI conversations from web-based AI tools and sends them to your local PCE instance.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content_scripts/pce_dom_utils.js", "content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/text_collector.js", "content_scripts/chatgpt.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content_scripts/pce_dom_utils.js", "content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/text_collector.js", "content_scripts/claude.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content_scripts/pce_dom_utils.js", "content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/text_collector.js", "content_scripts/gemini.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://aistudio.google.com/*"],
      "js": ["content_scripts/pce_dom_utils.js", "content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/text_collector.js", "content_scripts/google_ai_studio.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://manus.im/*"],
      "js": ["content_scripts/pce_dom_utils.js", "content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/text_collector.js", "content_scripts/manus.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["content_scripts/pce_dom_utils.js", "content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/text_collector.js", "content_scripts/deepseek.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://chat.z.ai/*"],
      "js": ["content_scripts/pce_dom_utils.js", "content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/text_collector.js", "content_scripts/zhipu.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.perplexity.ai/*"],
      "js": ["content_scripts/pce_dom_utils.js", "content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/text_collector.js", "content_scripts/perplexity.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://copilot.microsoft.com/*"],
      "js": ["content_scripts/pce_dom_utils.js", "content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/text_collector.js", "content_scripts/copilot.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://poe.com/*"],
      "js": ["content_scripts/pce_dom_utils.js", "content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/text_collector.js", "content_scripts/poe.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://huggingface.co/chat/*"],
      "js": ["content_scripts/pce_dom_utils.js", "content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/text_collector.js", "content_scripts/huggingface.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://grok.com/*"],
      "js": ["content_scripts/pce_dom_utils.js", "content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/text_collector.js", "content_scripts/grok.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://chat.mistral.ai/*",
        "https://kimi.moonshot.cn/*",
        "https://www.kimi.com/*",
        "https://kimi.com/*"
      ],
      "js": ["content_scripts/pce_dom_utils.js", "content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/text_collector.js", "content_scripts/generic.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content_scripts/detector.js"],
      "run_at": "document_idle",
      "exclude_matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://manus.im/*",
        "https://chat.deepseek.com/*",
        "https://chat.z.ai/*",
        "https://www.perplexity.ai/*",
        "https://grok.com/*",
        "https://poe.com/*",
        "https://copilot.microsoft.com/*",
        "https://huggingface.co/chat/*",
        "https://chat.mistral.ai/*",
        "https://kimi.moonshot.cn/*",
        "https://www.kimi.com/*",
        "https://kimi.com/*"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "interceptor/page_confirmed.js",
        "interceptor/ai_patterns.js",
        "interceptor/network_interceptor.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
