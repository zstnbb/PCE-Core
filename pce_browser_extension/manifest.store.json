{
  "manifest_version": 3,
  "name": "PCE - AI Interaction Capture",
  "version": "0.3.0",
  "description": "Captures AI conversations from web-based AI tools and sends them to your local PCE instance.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "http://127.0.0.1:9800/*",
    "http://localhost:9800/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*",
    "https://www.perplexity.ai/*",
    "https://grok.com/*",
    "https://poe.com/*",
    "https://copilot.microsoft.com/*",
    "https://huggingface.co/chat/*",
    "https://chat.mistral.ai/*",
    "https://kimi.moonshot.cn/*",
    "https://you.com/*",
    "https://pi.ai/*",
    "https://character.ai/*",
    "https://beta.character.ai/*",
    "https://phind.com/*",
    "https://devv.ai/*",
    "https://coral.cohere.com/*",
    "https://aistudio.google.com/*",
    "https://notebooklm.google.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/chatgpt.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/claude.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/gemini.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/deepseek.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.perplexity.ai/*"],
      "js": ["content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/perplexity.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://copilot.microsoft.com/*"],
      "js": ["content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/copilot.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://poe.com/*"],
      "js": ["content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/poe.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://huggingface.co/chat/*"],
      "js": ["content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/huggingface.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://grok.com/*",
        "https://chat.mistral.ai/*",
        "https://kimi.moonshot.cn/*",
        "https://you.com/*",
        "https://pi.ai/*",
        "https://character.ai/*",
        "https://beta.character.ai/*",
        "https://phind.com/*",
        "https://devv.ai/*",
        "https://coral.cohere.com/*",
        "https://aistudio.google.com/*",
        "https://notebooklm.google.com/*"
      ],
      "js": ["content_scripts/detector.js", "content_scripts/behavior_tracker.js", "content_scripts/bridge.js", "content_scripts/generic.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "interceptor/ai_patterns.js",
        "interceptor/network_interceptor.js"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*",
        "https://www.perplexity.ai/*",
        "https://grok.com/*",
        "https://poe.com/*",
        "https://copilot.microsoft.com/*",
        "https://huggingface.co/chat/*",
        "https://chat.mistral.ai/*",
        "https://kimi.moonshot.cn/*",
        "https://you.com/*",
        "https://pi.ai/*",
        "https://character.ai/*",
        "https://beta.character.ai/*",
        "https://phind.com/*",
        "https://devv.ai/*",
        "https://coral.cohere.com/*",
        "https://aistudio.google.com/*",
        "https://notebooklm.google.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
