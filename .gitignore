# OS
.DS_Store
Thumbs.db

# PCE data (user's local data should not be committed)
*.db
*.db-wal
*.db-shm

# mitmproxy
~/.mitmproxy/
/tests/e2e/screenshots
/tests/e2e/e2e_state.json
/tests/e2e/fixtures/generated/
/tests/e2e/reports/
/tests/e2e_probe/reports/
/tests/e2e_desktop_ui/reports/
/logs/

# Local probe diagnostics and scratch artifacts
/.diag_*
/.pytest_*.log
/.sessions_*.json
/.tmp_*
/.triage_*.txt
/tmp_*.txt
/tests/e2e/tmp_*
/scripts/_diag_*.py
/scripts/_dump_*.py

# Desktop UI sweep ephemeral state (tests/e2e_desktop_ui/* per-window logs +
# proxy runtime files + debug body dumps; the cases re-create these on every
# run, so committing would just churn).
/_window_*_log.txt
/_baseline_ts.txt
/_d06_dump/
/_mitm.out
/_mitm.err
/_mitm.pid

# Node / .mcpb bundles (ADR-016 §3.3 — pce_mcp/mcpb/)
node_modules/
*.mcpb
/pce_mcp/mcpb/pack-output/
/.git-commit-msg.txt

# Phase 4.0 manual recon artifacts — contain real Claude Desktop
# conversation content; never commit (only the .py / .md tooling
# itself is tracked).
/tests/manual/recon_*/
