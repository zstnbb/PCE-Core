{
  "name": "pce-browser-extension-wxt",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "description": "PCE browser extension — WXT-powered build chain (P2 migration, see README.md).",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "wxt": "^0.19.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/chrome": "^0.0.270",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "happy-dom": "^14.12.0",
    "fake-indexeddb": "^6.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
