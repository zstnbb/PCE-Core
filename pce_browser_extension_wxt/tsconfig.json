{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "noFallthroughCasesInSwitch": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "$probe-rpc": ["./entrypoints/background/probe-rpc.ts"],
      "$probe-rpc-capture": ["./entrypoints/background/probe-rpc-capture.ts"]
    }
  },
  "include": [
    "entrypoints/**/*",
    "utils/**/*",
    "test/**/*",
    "wxt.config.ts",
    "vitest.config.ts",
    "types.d.ts"
  ],
  "exclude": [
    "node_modules",
    ".wxt",
    ".output"
  ]
}
