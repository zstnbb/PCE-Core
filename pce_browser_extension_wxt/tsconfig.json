{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "noFallthroughCasesInSwitch": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "types": ["chrome"]
  },
  "include": [
    "entrypoints/**/*",
    "utils/**/*",
    "wxt.config.ts",
    "types.d.ts"
  ],
  "exclude": [
    "node_modules",
    ".wxt",
    ".output"
  ]
}
